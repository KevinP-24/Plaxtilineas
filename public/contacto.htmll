<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <!-- SEO -->
  <meta name="description" content="PlaxtiLineas - Soluciones en insumos para marroquinería, tapicería, construcción, hogar y agricultura. Calidad y servicio garantizados.">
  <meta name="keywords" content="marroquinería, tapicería, construcción, insumos, hogar, agricultura, materiales, distribución">
  <meta name="author" content="PlaxtiLineas">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="https://plaxtilineas.com">

  <!-- Open Graph (para compartir en redes sociales) -->
  <meta property="og:title" content="PlaxtiLineas - Insumos para múltiples industrias">
  <meta property="og:description" content="Líderes en la distribución de insumos esenciales para marroquinería, tapicería, construcción y más.">
  <meta property="og:image" content="https://plaxtilineas.com/img/logo.png">
  <meta property="og:url" content="https://plaxtilineas.com">
  <meta property="og:type" content="website">
  
  <!-- Twitter Cards (para optimización en Twitter) -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="PlaxtiLineas - Insumos para múltiples industrias">
  <meta name="twitter:description" content="Distribuimos insumos de calidad para marroquinería, tapicería, construcción, hogar y más.">
  <meta name="twitter:image" content="https://plaxtilineas.com/img/logo.png">

  <!-- Iconos y Favicon -->
  <link rel="icon" href="/img/favicon.ico" type="image/x-icon">
  <link rel="apple-touch-icon" sizes="180x180" href="/img/apple-touch-icon.png">

  <!-- Estilos CSS -->
  <link rel="stylesheet" href="/css/style_navbar.css">
  <link rel="stylesheet" href="/css/botoneSociales.css">
  <link rel="stylesheet" href="/css/asistente.css">
  <link rel="stylesheet" href="/css/mapaCuadrado.css">
  <link rel="stylesheet" href="/css/aliados.css">
  <link rel="stylesheet" href="/css/footer.css">

  <!-- Datos estructurados Schema.org -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "PlaxtiLineas",
    "url": "https://plaxtilineas.com",
    "logo": "https://plaxtilineas.com/img/logo.png",
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+57 3113416659",
      "contactType": "customer service"
    },
    "sameAs": [
      "https://www.facebook.com/plaxtilineas",
      "https://www.instagram.com/plaxtilineas/",
      "https://wa.me/1234567890"
    ]
  }
  </script>
</head>

<body>



<!--Seccion donde se insertara el mapa-->
  <section class="contenidoM mapa">
    <h2 class="title">¡Encuéntranos en!</h2>
    <p class="map-subtitle">Visítanos en nuestra ubicación física en Armenia, Quindío.</p>
    
    <div class="map-container">
      <iframe 
        src="https://www.google.com/maps/embed?pb=!4v1733971947234!6m8!1m7!1srsqHEySLHOzmaXYDg-wMgg!2m2!1d4.535668507113891!2d-75.67495696103823!3f150.42944478021346!4f-11.723004583918524!5f0.9750208071456414" 
        width="100%" 
        height="400" 
        allowfullscreen="" 
        loading="lazy" 
        referrerpolicy="no-referrer-when-downgrade">
      </iframe>
    </div>
    <div class="map-buttons">
        <a href="https://www.google.com/maps/dir/?api=1&destination=Cra.19+%23+19-35+Armenia+Quindio" class="btn2">
            <span class="spn2">Abirir en Google Maps</span>
        </a>
    </div>
  </section>


  <section class="marcas-aliadas">
    <h2>Distribuidores Oficiales de:</h2>
    <div class="brands-container">
        <img src="./img/logo-plastextil.png" alt="Calypso Proyectos" class="brand-logo">
        <img src="./img/espumas_santafe.png" alt="Proquinal" class="brand-logo">
        <img src="./img/espumas_medellin.png" alt="La Sabana" class="brand-logo">
        <img src="./img/Testicol.png" alt="Spradling" class="brand-logo">
        <img src="./img/POLYLON.png" alt="Spradling" class="brand-logo">
        <img src="./img/grupoExcala.png" alt="Spradling" class="brand-logo">
        <img src="./img/logo-pegatex.png" alt="Spradling" class="brand-logo">
        <img src="./img/preflex.png" alt="Spradling" class="brand-logo">
    </div>
  </section>


  <!-- Scripts -->
  <script src="js/cargarNavbar.js"></script>
  <script src="js/logicaNavBar.js"></script>
  <div class="help-message" id="helpMessage">¿Necesitas ayuda?</div> 
  <script src="js/cargarBotones.js"></script>
  <script src="js/cargarFooter.js"></script>

</body>
</html>